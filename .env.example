# =============================================================================
# PulseCompanion Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# All variables have sensible defaults and are optional.

# -----------------------------------------------------------------------------
# Ollama LLM Configuration
# -----------------------------------------------------------------------------

# Base URL for the Ollama API server
OLLAMA_BASE_URL=http://localhost:11434

# Primary language model used for generating responses
OLLAMA_MODEL=phi3:mini

# Embedding model used for semantic memory search
OLLAMA_EMBED_MODEL=nomic-embed-text

# -----------------------------------------------------------------------------
# ChromaDB Vector Store Configuration
# -----------------------------------------------------------------------------

# File path for ChromaDB persistent storage
CHROMADB_PATH=./chroma_data

# Name of the ChromaDB collection for storing conversation memory
CHROMADB_COLLECTION=pulse_companion_memory

# -----------------------------------------------------------------------------
# API & Server Configuration
# -----------------------------------------------------------------------------

# Allowed CORS origins (JSON array format)
CORS_ORIGINS=["http://localhost:3000"]

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Memory & Session Configuration
# -----------------------------------------------------------------------------

# Maximum number of memory results returned during context retrieval
MAX_MEMORY_RESULTS=3

# Session inactivity timeout in minutes
SESSION_TIMEOUT_MINUTES=30
